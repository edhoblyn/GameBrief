<%= form_with model: [patch, chat, message], html: { class: "chatbot__form" } do |f| %>
  <%= hidden_field_tag :return_to, params[:return_to] %>
  <div class="chatbot__input-row">
    <%= f.text_field :content,
          placeholder: "Ask a question about this patch...",
          class: "chatbot__input",
          required: true,
          autocomplete: "off" %>

    <%= f.submit "Ask", class: "chatbot__submit" %>
  </div>
<% end %>
