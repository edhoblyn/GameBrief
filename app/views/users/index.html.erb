<% content_for :title, "Players" %>

<div class="container" style="padding-top: 100px;">
  <div class="mb-4">
    <%= link_to my_profile_path, class: "btn btn-outline-secondary mb-3" do %>
      <i class="fa fa-arrow-left"></i> Back to Profile
    <% end %>
    <h1 class="mb-0">Players</h1>
  </div>

  <% if @users.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% @users.each do |user| %>
        <div class="col">
          <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
              <div class="profile-sidebar__avatar-placeholder flex-shrink-0" style="width:48px;height:48px;font-size:1.2rem;">
                <%= (user.username.presence || user.email).first.upcase %>
              </div>
              <div>
                <h5 class="card-title mb-0"><%= user.username.presence || user.email %></h5>
                <% if user.username.present? %>
                  <p class="text-muted small mb-0"><%= user.email %></p>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No other players yet.</p>
  <% end %>
</div>
