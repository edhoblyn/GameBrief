<div class="container" style="padding-top: 100px; padding-bottom: 48px;">
  <div class="mb-4">
    <%= link_to users_path, class: "btn btn-outline-secondary mb-3" do %>
      <i class="fa fa-arrow-left"></i> Back to Players
    <% end %>
    <h1 class="mb-1"><%= @user.display_name %></h1>
    <p class="text-muted mb-0"><%= @user.email %></p>
  </div>

  <div class="row g-4">
    <div class="col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h2 class="h5">Profile</h2>
          <p class="mb-2"><strong>Handle:</strong> @<%= @user.profile_handle %></p>
          <p class="mb-2"><strong>Role:</strong> <%= @user.role.humanize %></p>
          <p class="mb-0"><strong>Provider:</strong> <%= @user.provider.presence || "Email" %></p>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card h-100">
        <div class="card-body">
          <h2 class="h5">Activity</h2>
          <p class="mb-2"><strong>Followed games:</strong> <%= @games_count %></p>
          <p class="mb-0"><strong>Event reminders:</strong> <%= @reminders_count %></p>
        </div>
      </div>
    </div>
  </div>
</div>
