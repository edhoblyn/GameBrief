<nav class="hover-gradient-nav">
  <ul>

    <li class="hn-item">
      <div class="hn-card">
        <a href="<%= root_path %>" class="hn-front">Home</a>
      </div>
    </li>

    <li class="hn-item">
      <div class="hn-card">
        <a href="<%= games_path %>" class="hn-front">Games</a>
      </div>
    </li>

    <li class="hn-item">
      <div class="hn-card">
        <a href="<%= events_path %>" class="hn-front">Events</a>
      </div>
    </li>

    <% if user_signed_in? %>
      <li class="hn-item">
        <div class="hn-card<%= ' hn-card--dashboard' if content_for?(:on_dashboard) %>">
          <details class="hn-sidebar-toggle-details">
            <summary class="hn-front hn-dashboard-summary">
              Loadout
            </summary>
            <nav class="dropdown-menu profile-sidebar__nav">
              <a href="<%= my_profile_path %>" class="profile-sidebar__nav-link profile-sidebar__nav-link--active">
                <i class="fa fa-user"></i> My Profile
              </a>
              <a href="<%= my_games_path %>" class="profile-sidebar__nav-link">
                <i class="fa fa-gamepad"></i> My Games
                <span class="badge bg-secondary ms-auto"><%= @followed_games&.count || current_user.favourite_games.count %></span>
              </a>
              <a href="<%= my_patches_path %>" class="profile-sidebar__nav-link">
                <i class="fa fa-file-text"></i> My Patches
                <span class="badge bg-secondary ms-auto"><%= @recent_patches&.count || 0 %></span>
              </a>
              <a href="<%= my_events_path %>" class="profile-sidebar__nav-link">
                <i class="fa fa-calendar"></i> My Events
                <span class="badge bg-secondary ms-auto"><%= @reminders&.count || current_user.reminders.count %></span>
              </a>
              <a href="#recommendations" class="profile-sidebar__nav-link">
                <i class="fa fa-star"></i> My Recommendations
              </a>
              <%= link_to find_friends_path, class: "profile-sidebar__nav-link" do %>
                <i class="fa fa-users"></i> Find friends
              <% end %>
              <% if current_user.admin? %>
                <%= link_to admin_dashboard_path, class: "profile-sidebar__nav-link" do %>
                  <i class="fa fa-shield"></i> Admin Panel
                <% end %>
              <% end %>
            </nav>
          </details>
        </div>
      </li>
    <% else %>
      <li class="hn-item">
        <div class="hn-card">
          <a href="<%= new_user_session_path %>" class="hn-front">Login</a>
        </div>
      </li>
    <% end %>

  </ul>
</nav>

<% if content_for?(:on_dashboard) %>
  <script>
    function toggleProfileSidebar(btn) {
      const sidebar = document.getElementById('profile-sidebar__nav');
      if (!sidebar) return;
      sidebar.classList.toggle('d-none');
      const icon = document.getElementById('sidebar-toggle-icon');
      icon.className = sidebar.classList.contains('profile-sidebar--hidden')
        ? 'fa fa-chevron-down'
        : 'fa fa-chevron-up';
    }
  </script>
<% end %>
