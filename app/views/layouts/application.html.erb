<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Game Brief" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Game Brief">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <script>
      (function() {
        var savedTheme = localStorage.getItem("gamebrief-theme");
        if (savedTheme) document.documentElement.setAttribute("data-theme", savedTheme);
      })();
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme">
    <%= render "shared/hover_gradient_nav" unless content_for?(:hide_navbar) %>
    <%= render "shared/settings_menu" %>
    <%= render "shared/flashes" %>

    <%= yield %>

    <footer class="app-footer">
      <p class="app-footer__copy">GameBrief &copy; <%= Time.current.year %></p>
      <div class="app-footer__links">
        <%= link_to "Ed", "https://github.com/edhoblyn", class: "app-footer__link", target: "_blank", rel: "noopener noreferrer" %>
        <%= link_to "Hortense", "https://github.com/Hfvtt", class: "app-footer__link", target: "_blank", rel: "noopener noreferrer" %>
        <%= link_to "Baptiste", "https://github.com/Baptistesrd", class: "app-footer__link", target: "_blank", rel: "noopener noreferrer" %>
        <%= link_to "Bianca", "https://github.com/biancacorreia", class: "app-footer__link", target: "_blank", rel: "noopener noreferrer" %>
      </div>
    </footer>
  </body>
</html>
