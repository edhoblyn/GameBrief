<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Game Brief" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Game Brief">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='18' fill='%231a1a27'/><text x='50' y='68' font-size='52' font-family='Arial,sans-serif' font-weight='900' fill='%237c5cfc' text-anchor='middle'>GB</text></svg>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "shared/hover_gradient_nav" unless content_for?(:hide_navbar) %>
    <%= render "shared/flashes" %>

    <%= yield %>

    <footer class="app-footer">
      <p>GameBrief &copy; <%= Time.current.year %> &mdash; Ed, Hortense, Baptiste, Bianca</p>
    </footer>
  </body>
</html>
