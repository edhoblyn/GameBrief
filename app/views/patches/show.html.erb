<div class="patch-show">
  <div class="patch-show__header container">
    <div class="patch-show__header__breadcrumb">
      <%= link_to @patch.game.name, game_path(@patch.game) %> &rsaquo; Patches
    </div>
    <h1><%= @patch.title %></h1>
  </div>

  <div class="container">
    <div class="row g-4">
      <div class="col-lg-6">
        <h2 class="patch-show__section-title">Patch Notes</h2>
        <pre class="patch-show__raw-notes"><%= @patch.content %></pre>
      </div>

      <div class="col-lg-6">
        <h2 class="patch-show__section-title">AI Summaries</h2>

        <% SummaryService::LABELS.each do |type, label| %>
          <div class="summary-card mb-3">
            <div class="summary-card__label">
              <i class="fa fa-magic"></i> <%= label %>
            </div>
            <% if (summary = @summaries_by_type[type]) %>
              <p class="summary-card__text"><%= summary.summary %></p>
            <% else %>
              <p style="color: #7a7a9a; font-style: italic; font-size: 0.9rem;">Not generated yet.</p>
            <% end %>
            <%= button_to "Generate #{label}", generate_summary_patch_path(@patch), method: :post,
                params: { summary_type: type },
                class: "btn btn-sm btn-outline-secondary mt-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= link_to "Back to patches", game_patches_path(@patch.game) %>
