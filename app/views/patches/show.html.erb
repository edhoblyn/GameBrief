<div class="patch-show">
  <div class="patch-show__header container">
    <div class="patch-show__header__breadcrumb">
      <%= link_to @patch.game.name, game_path(@patch.game) %> &rsaquo; Patches
    </div>
    <h1><%= @patch.title %></h1>
    <p class="patch-show__meta"><%= @patch.display_published_at.to_date.to_fs(:long) %></p>
  </div>

  <div class="container">
    <div class="container mt-3 mb-3">
      <%= link_to game_patches_path(@patch.game), class: "btn btn-sm", style: "background: #581c87; color: #fff; border: none;" do %>
        &larr; Back to patches
      <% end %>
    </div>

    <div class="row g-4">
      <div class="col-lg-6">
        <h2 class="patch-show__section-title">Patch Notes</h2>
        <pre class="patch-show__raw-notes"><%= @patch.content %></pre>
      </div>

      <% if user_signed_in? && @chat %>
        <div class="col-lg-6">
          <div class="chatbot">
            <div class="chatbot__header">
              Ask about this patch
            </div>

            <div id="messages" class="chatbot__messages">
              <%= render "messages/messages", messages: @chat.messages %>
              <% if @chat.messages.empty? %>
                <p class="chatbot__empty">Ask anything about this patch — e.g. "What changed for snipers?" or "Should I log in?"</p>
              <% end %>
            </div>

            <div id="new_message_container">
              <%= render "messages/form", patch: @patch, chat: @chat, message: Message.new %>
            </div>

            <p class="chatbot__limit text-muted small mt-2 text-end">
              <%= @chat.messages.where(role: "user").count %> / <%= Message::MAX_USER_MESSAGES %> messages used
            </p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
