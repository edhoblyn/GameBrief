<div class="patches-index">
  <div class="patches-index__header container">
    <% if @game %>
      <%= link_to "← #{@game.name}", game_path(@game), style: "font-size:0.82rem; color: #7a7a9a; text-decoration:none;" %>
    <% end %>
    <h1>Patches</h1>
  </div>

  <div class="container">
    <div class="patches-index__filters">
      <% form_action = @game ? game_patches_path(@game) : patches_path %>

      <%= form_with url: form_action, method: :get, local: true, class: "patches-index__filter-form" do %>
        <%= hidden_field_tag :sort, @sort %>
        <%= label_tag :date_filter, "Filter by date", class: "patches-index__filter-label" %>
        <%= select_tag :date_filter,
              options_for_select(Patch::DATE_FILTERS.map { |value, label| [label, value] }, @date_filter),
              class: "patches-index__filter-select",
              onchange: "this.form.requestSubmit()" %>
      <% end %>

      <div class="patches-index__sort-group">
        <%= link_to "Recommended", (@game ? game_patches_path(@game, date_filter: @date_filter, sort: "recommended") : patches_path(date_filter: @date_filter, sort: "recommended")), class: "filter-btn #{@sort == 'recommended' ? 'active' : ''}" %>
        <%= link_to "Newest", (@game ? game_patches_path(@game, date_filter: @date_filter, sort: "newest") : patches_path(date_filter: @date_filter, sort: "newest")), class: "filter-btn #{@sort == 'newest' ? 'active' : ''}" %>
        <%= link_to "A–Z", (@game ? game_patches_path(@game, date_filter: @date_filter, sort: "title") : patches_path(date_filter: @date_filter, sort: "title")), class: "filter-btn #{@sort == 'title' ? 'active' : ''}" %>
        <%= link_to "Oldest", (@game ? game_patches_path(@game, date_filter: @date_filter, sort: "oldest") : patches_path(date_filter: @date_filter, sort: "oldest")), class: "filter-btn #{@sort == 'oldest' ? 'active' : ''}" %>
      </div>
    </div>

    <% if @patches.any? %>
      <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% @patches.each do |patch| %>
          <div class="col">
            <%= link_to patch_path(patch), class: "text-decoration-none" do %>
              <div class="card h-100">
                <div class="card-body">
                  <p class="text-muted small mb-1"><%= patch.game.name %></p>
                  <h5 class="card-title"><%= patch.title %></h5>
                  <p class="patches-index__date"><%= patch.display_published_at ? patch.display_published_at.to_date.to_fs(:long) : "Date unavailable" %></p>
                  <p class="card-text text-muted small"><%= patch.content.truncate(100) %></p>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <p style="color: #7a7a9a; font-style: italic;">No patches found for that date range.</p>
    <% end %>
  </div>
</div>
