<div class="home-page">
  <hr class="nav-divider">

  <div class="home-landing__corner">
    <%= image_tag "logo.svg", alt: "GameBrief", class: "home-landing__logo", height: "36" %>
  </div>

  <div class="home-landing">
    <div class="home-landing__video-bg">
      <%= video_tag "owyeah.mp4", autoplay: true, muted: true, loop: true, playsinline: true %>
    </div>
    <div class="home-landing__video-overlay"></div>
    <div class="home-landing__fade"></div>

    <div class="home-landing__content">
      <h2 class="home-landing__heading">Stay in the loop.<br>Skip the wall of text.</h2>
      <p class="home-landing__subtitle">Patch notes. Plain English.</p>

      <div class="home-landing__actions">
        <% if user_signed_in? %>
          <%= link_to "See My Profile", my_profile_path, class: "home-landing__button home-landing__button--primary" %>
        <% else %>
          <%= link_to "Get Started", new_user_registration_path, class: "home-landing__button home-landing__button--primary" %>
        <% end %>
        <%= link_to "Explore Games", games_path, class: "home-landing__button home-landing__button--secondary" %>
      </div>

      <div class="home-landing__stats">
        <div class="home-landing__stat">
          <i class="fa fa-bolt"></i>
          <span>12K+ Active Now</span>
        </div>
        <div class="home-landing__stat-divider"></div>
        <div class="home-landing__stat">
          <i class="fa fa-users"></i>
          <span>500+ Communities</span>
        </div>
        <div class="home-landing__stat-divider"></div>
        <div class="home-landing__stat">
          <i class="fa fa-gamepad"></i>
          <span>10K+ Games Tracked</span>
        </div>
      </div>
    </div>
  </div>

  <div class="gamers-carousel" data-controller="gamers-carousel">
    <p class="gamers-carousel__label">Featured Gamers</p>
    <div class="gamers-carousel__viewport">
      <div class="gamers-carousel__track" data-gamers-carousel-target="track">
        <% @featured_gamers.each do |gamer| %>
          <div class="gamers-carousel__card">
            <% if gamer.avatar_image.attached? %>
              <%= image_tag gamer.avatar_image, alt: gamer.display_name, class: "gamers-carousel__avatar" %>
            <% elsif gamer.avatar_url.present? %>
              <%= image_tag gamer.avatar_url, alt: gamer.display_name, class: "gamers-carousel__avatar" %>
            <% else %>
              <div class="gamers-carousel__avatar gamers-carousel__avatar--placeholder"><%= gamer.display_name.first.upcase %></div>
            <% end %>
            <span class="gamers-carousel__name"><%= gamer.display_name %></span>
            <span class="gamers-carousel__handle">@<%= gamer.profile_handle %></span>
            <span class="gamers-carousel__followers">
              <i class="fa fa-users"></i> <%= number_with_delimiter(gamer.follower_count) %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="gamers-carousel__controls">
      <button class="gamers-carousel__btn" data-action="click->gamers-carousel#prev">
        <i class="fa fa-chevron-left"></i>
      </button>
      <button class="gamers-carousel__btn" data-action="click->gamers-carousel#next">
        <i class="fa fa-chevron-right"></i>
      </button>
    </div>
  </div>

<% if user_signed_in? %>
    <div class="home-landing__logout">
      <%= button_to destroy_user_session_path, method: :delete, class: "logout-btn" do %>
        <i class="fa fa-sign-out"></i> Log out
      <% end %>
    </div>
  <% end %>
</div>
