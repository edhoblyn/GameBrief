<div class="home-page">
  <hr class="nav-divider">

  <div class="home-landing__corner">
    <h1 class="home-landing__title">GameBrief</h1>
  </div>

  <div class="home-landing">
    <div class="home-landing__video-bg">
      <%= video_tag "owyeah.mp4", autoplay: true, muted: true, loop: true, playsinline: true %>
    </div>
    <div class="home-landing__video-overlay"></div>

    <div class="home-landing__content">
      <h2 class="home-landing__heading">Stay in the loop.<br>Skip the wall of text.</h2>
      <p class="home-landing__subtitle">GameBrief turns complex patch notes into plain-English summaries so you know exactly what changed — and whether it's worth logging in.</p>

      <div class="home-landing__actions">
        <% if user_signed_in? %>
          <%= link_to "See My Profile", my_profile_path, class: "btn btn-primary btn-lg" %>
        <% else %>
          <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg" %>
        <% end %>
        <%= link_to "Explore Games", games_path, class: "btn btn-outline-light btn-lg" %>
      </div>

      <div class="home-landing__stats">
        <div class="home-landing__stat">
          <i class="fa fa-bolt"></i>
          <span>12K+ Active Now</span>
        </div>
        <div class="home-landing__stat-divider"></div>
        <div class="home-landing__stat">
          <i class="fa fa-users"></i>
          <span>500+ Communities</span>
        </div>
        <div class="home-landing__stat-divider"></div>
        <div class="home-landing__stat">
          <i class="fa fa-gamepad"></i>
          <span>10K+ Games Tracked</span>
        </div>
      </div>
    </div>
  </div>

  <div class="featured-gamers">
    <p class="featured-gamers__label">Featured Gamers</p>
    <div class="featured-gamers__list">
      <% @featured_gamers.each do |gamer| %>
        <div class="featured-gamers__item">
          <img src="<%= gamer.avatar_url %>" alt="<%= gamer.username %>" class="featured-gamers__avatar">
          <span class="featured-gamers__username">@<%= gamer.username %></span>
          <span class="featured-gamers__followers"><i class="fa fa-user"></i> <%= number_with_delimiter(gamer.follower_count) %></span>
        </div>
      <% end %>
    </div>
  </div>

<% if user_signed_in? %>
    <div class="home-landing__logout">
      <%= button_to destroy_user_session_path, method: :delete, class: "logout-btn" do %>
        <i class="fa fa-sign-out"></i> Log out
      <% end %>
    </div>
  <% end %>
</div>
