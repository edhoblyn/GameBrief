<div class="home-page">
  <div style="height: 4rem;"></div>
  <div class="home-landing__corner">
    <%= image_tag "logo.svg", alt: "GameBrief", class: "home-landing__logo", height: "36" %>
  </div>

  <div class="home-landing">
    <div class="home-landing__video-bg">
      <%= video_tag "owyeah.mp4", autoplay: true, muted: true, loop: true, playsinline: true %>
    </div>
    <div class="home-landing__video-overlay"></div>
    <div class="home-landing__fade"></div>

    <div class="home-landing__content">
      <h2 class="home-landing__heading">Stay in the loop.<br>Skip the wall of text.</h2>
      <p class="home-landing__subtitle">Patch notes. Plain English.</p>

      <div class="home-landing__actions">
        <% if user_signed_in? %>
          <%= link_to "See My Profile", my_profile_path, class: "home-landing__button home-landing__button--primary" %>
        <% else %>
          <%= link_to "Get Started", new_user_registration_path, class: "home-landing__button home-landing__button--primary" %>
        <% end %>
        <%= link_to "Explore Games", games_path, class: "home-landing__button home-landing__button--secondary" %>
      </div>

      <div class="home-landing__stats">
        <div class="home-landing__stat">
          <i class="fa fa-bolt"></i>
          <span>12K+ Active Now</span>
        </div>
        <div class="home-landing__stat-divider"></div>
        <div class="home-landing__stat">
          <i class="fa fa-users"></i>
          <span>500+ Communities</span>
        </div>
        <div class="home-landing__stat-divider"></div>
        <div class="home-landing__stat">
          <i class="fa fa-gamepad"></i>
          <span>10K+ Games Tracked</span>
        </div>
      </div>

      <% if @trending_games.any? %>
        <div class="trending-carousel">
          <p class="trending-carousel__title">Trending Games</p>
          <div class="trending-carousel__wrapper">
            <button class="btn btn-dark" onclick="trendingScroll(-1)">&#8249;</button>
            <div class="trending-carousel__viewport">
              <div class="trending-carousel__track" id="trendingTrack">
                <% @trending_games.each do |game| %>
                  <%= link_to game_path(game), class: "trending-carousel__card" do %>
                    <% if game.cover_image.present? %>
                      <%= image_tag game.cover_image, alt: game.name, class: "trending-carousel__img" %>
                    <% else %>
                      <div class="trending-carousel__placeholder">
                        <i class="fa fa-gamepad"></i>
                      </div>
                    <% end %>
                    <p class="trending-carousel__name"><%= game.name %></p>
                  <% end %>
                <% end %>
              </div>
            </div>
            <button class="btn btn-dark" onclick="trendingScroll(1)">&#8250;</button>
          </div>
        </div>

        <script>
          function trendingScroll(dir) {
            var track = document.getElementById("trendingTrack");
            var card = track.querySelector(".trending-carousel__card");
            var cardWidth = card.offsetWidth + 16; // card + gap
            track.scrollBy({ left: dir * cardWidth * 5, behavior: "smooth" });
          }
        </script>
      <% end %>

    </div>
  </div>

<% if user_signed_in? %>
    <div class="home-landing__logout">
      <%= button_to destroy_user_session_path, method: :delete, class: "logout-btn" do %>
        <i class="fa fa-sign-out"></i> Log out
      <% end %>
    </div>
  <% end %>
</div>
