<% content_for :title, "Find Friends" %>

<div class="container" style="padding-top: 100px;">
  <div class="mb-4">
    <%= link_to my_profile_path, class: "btn btn-outline-secondary mb-3" do %>
      <i class="fa fa-arrow-left"></i> Back to Profile
    <% end %>
    <h1 class="mb-0">Find Friends</h1>
  </div>

  <%= form_with url: find_friends_path, method: :get, local: true, class: "mb-4" do |f| %>
    <div class="input-group" style="max-width: 480px;">
      <%= f.text_field :q, value: params[:q], placeholder: "Search by username…",
            class: "form-control form-control-lg", autofocus: true %>
      <button type="submit" class="btn btn-primary">
        <i class="fa fa-search"></i>
      </button>
    </div>
  <% end %>

  <% if params[:q].present? %>
    <p class="text-muted mb-3">
      <%= @users.count %> result<%= "s" if @users.count != 1 %> for "<%= params[:q] %>"
    </p>
  <% end %>

  <% if @users.any? %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
      <% @users.each do |user| %>
        <div class="col">
          <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
              <div class="profile-sidebar__avatar-placeholder flex-shrink-0"
                   style="width: 48px; height: 48px; font-size: 1.2rem; border-radius: 50%;">
                <%= (user.username.presence || user.email).first.upcase %>
              </div>
              <div>
                <h6 class="mb-0 fw-semibold"><%= user.username.presence || user.email %></h6>
                <% if user.username.present? %>
                  <small class="text-muted"><%= user.email %></small>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% elsif params[:q].present? %>
    <p class="text-muted">No users found for "<%= params[:q] %>".</p>
  <% else %>
    <p class="text-muted">Search for a username above to find friends.</p>
  <% end %>
</div>
