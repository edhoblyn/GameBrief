<% content_for :title, "Find Friends" %>

<div class="find-friends-page container">
  <div class="find-friends-page__header">
    <div>
      <%= link_to my_profile_path, class: "find-friends-page__back" do %>
        <i class="fa fa-arrow-left"></i> Back to Profile
      <% end %>
      <p class="find-friends-page__eyebrow">Social</p>
      <h1 class="find-friends-page__title">Find Friends</h1>
      <p class="find-friends-page__subtitle">Search for players by username and jump into shared interests faster.</p>
    </div>
  </div>

  <%= form_with url: find_friends_path, method: :get, local: true, class: "find-friends-page__search" do |f| %>
    <div class="find-friends-page__search-row">
      <%= f.text_field :q, value: params[:q], placeholder: "Search by username…",
            class: "find-friends-page__search-input", autofocus: true %>
      <button type="submit" class="find-friends-page__search-button">
        <i class="fa fa-search"></i>
      </button>
    </div>
  <% end %>

  <% if params[:q].present? %>
    <p class="find-friends-page__results">
      <%= @users.count %> result<%= "s" if @users.count != 1 %> for "<%= params[:q] %>"
    </p>
  <% end %>

  <% if @users.any? %>
    <div class="find-friends-page__grid">
      <% @users.each do |user| %>
        <div class="find-friends-page__card">
          <div class="find-friends-page__card-body">
            <div class="find-friends-page__avatar">
              <%= (user.username.presence || user.email).first.upcase %>
            </div>
            <div>
              <h2 class="find-friends-page__name"><%= user.username.presence || user.email %></h2>
              <% if user.username.present? %>
                <p class="find-friends-page__email"><%= user.email %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% elsif params[:q].present? %>
    <div class="find-friends-page__empty">
      <p>No users found for "<%= params[:q] %>".</p>
    </div>
  <% else %>
    <div class="find-friends-page__empty">
      <p>Search for a username above to find friends.</p>
    </div>
  <% end %>
</div>

<script>
  (function () {
    var page    = document.getElementById('findFriendsPage');
    var input   = document.getElementById('friendsSearchInput');
    var results = document.getElementById('friendsResults');
    var timer   = null;

    if (!page || !input) return;

    input.addEventListener('focus', function () {
      page.classList.add('is-focused');
    });

    input.addEventListener('blur', function () {
      if (!input.value.trim()) {
        page.classList.remove('is-focused');
        results.style.display = 'none';
      }
    });

    input.addEventListener('input', function () {
      clearTimeout(timer);
      var q = input.value.trim();

      if (!q) {
        results.style.display = 'none';
        results.innerHTML = '';
        return;
      }

      timer = setTimeout(function () {
        fetch('<%= find_friends_path %>.json?q=' + encodeURIComponent(q), {
          headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) { return r.json(); })
        .then(function (users) {
          renderResults(users, q);
        });
      }, 250);
    });

    function renderResults(users, q) {
      var count = users.length;
      var label = count + ' result' + (count !== 1 ? 's' : '') + ' for \u201C' + escHtml(q) + '\u201D';

      var html = '<p class="text-muted small mb-3">' + label + '</p>';

      if (count > 0) {
        html += '<div class="row row-cols-1 row-cols-md-2 g-3">';
        users.forEach(function (u, i) {
          html += '<div class="col ff-result-card">' +
            '<div class="card h-100 border-0 shadow-sm">' +
              '<div class="card-body d-flex align-items-center gap-3">' +
                '<div class="profile-sidebar__avatar-placeholder flex-shrink-0" ' +
                     'style="width:48px;height:48px;font-size:1.2rem;border-radius:50%;">' +
                  escHtml(u.initial) +
                '</div>' +
                '<div>' +
                  '<h6 class="mb-0 fw-semibold">' + escHtml(u.display) + '</h6>' +
                  (u.email ? '<small class="text-muted">' + escHtml(u.email) + '</small>' : '') +
                '</div>' +
              '</div>' +
            '</div>' +
          '</div>';
        });
        html += '</div>';
      } else {
        html += '<p class="text-muted">No users found for \u201C' + escHtml(q) + '\u201D.</p>';
      }

      results.innerHTML = html;
      results.style.display = 'block';
    }

    function escHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
  })();
</script>
