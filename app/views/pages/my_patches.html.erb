<% content_for :title, "My Patches" %>

<div class="my-patches-page container">
  <div class="my-patches-page__header">
    <div>
      <p class="my-patches-page__eyebrow">Profile</p>
      <h1 class="my-patches-page__title">My Patches</h1>
      <p class="my-patches-page__subtitle">Recent patch notes from the games you follow.</p>
    </div>
    <div class="my-patches-page__actions">
      <%= link_to my_profile_path, class: "my-patches-page__action" do %>
        <i class="fa fa-arrow-left"></i>
        Back to Profile
      <% end %>
      <%= link_to my_games_path, class: "my-patches-page__action my-patches-page__action--primary" do %>
        <i class="fa fa-gamepad"></i>
        My Games
      <% end %>
    </div>
  </div>

  <div class="my-patches-page__summary">
    <div class="my-patches-page__summary-card">
      <span class="my-patches-page__summary-value"><%= @patches.count %></span>
      <span class="my-patches-page__summary-label">Visible patches</span>
    </div>
    <div class="my-patches-page__summary-card">
      <span class="my-patches-page__summary-value"><%= @followed_games.count %></span>
      <span class="my-patches-page__summary-label">Followed games</span>
    </div>
  </div>

  <div class="my-patches-page__filters">
    <%= form_with url: my_patches_path, method: :get, local: true, class: "my-patches-page__filter-form" do %>
      <div class="my-patches-page__filter-group">
        <%= label_tag :date_filter, "Date range", class: "my-patches-page__filter-label" %>
        <%= select_tag :date_filter,
              options_for_select(Patch::DATE_FILTERS.map { |value, label| [label, value] }, @date_filter),
              class: "my-patches-page__filter-select",
              onchange: "this.form.requestSubmit()" %>
      </div>

      <div class="my-patches-page__sort-group">
        <%= link_to "Newest", my_patches_path(date_filter: @date_filter, sort: "newest"), class: "filter-btn #{@sort == 'newest' ? 'active' : ''}" %>
        <%= link_to "Oldest", my_patches_path(date_filter: @date_filter, sort: "oldest"), class: "filter-btn #{@sort == 'oldest' ? 'active' : ''}" %>
      </div>
    <% end %>
  </div>

  <% if @patches.any? %>
    <div class="my-patches-page__grid">
      <% @patches.each do |patch| %>
        <%= link_to patch_path(patch), class: "my-patches-page__card" do %>
          <div class="my-patches-page__card-top">
            <span class="my-patches-page__game"><%= patch.game.name %></span>
            <span class="my-patches-page__date"><%= patch.display_published_at.to_date.to_fs(:long) %></span>
          </div>
          <h2 class="my-patches-page__card-title"><%= patch.title %></h2>
          <p class="my-patches-page__card-copy"><%= patch.content.to_s.truncate(140) %></p>
          <span class="my-patches-page__card-cta">Read patch <i class="fa fa-arrow-right"></i></span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="my-patches-page__empty">
      <div class="my-patches-page__empty-icon">
        <i class="fa fa-file-text"></i>
      </div>
      <h2 class="my-patches-page__empty-title">No patches found for your followed games</h2>
      <p class="my-patches-page__empty-copy">Try a wider date range or follow more games to build your patch feed.</p>
      <div class="my-patches-page__actions">
        <%= link_to my_games_path, class: "my-patches-page__action" do %>
          <i class="fa fa-gamepad"></i>
          View My Games
        <% end %>
        <%= link_to games_path, class: "my-patches-page__action my-patches-page__action--primary" do %>
          <i class="fa fa-search"></i>
          Browse All Games
        <% end %>
      </div>
    </div>
  <% end %>
</div>
