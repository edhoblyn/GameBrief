<h1><%= @event.title %></h1>

<p><strong>Game:</strong> <%= link_to @event.game.name, game_path(@event.game) %></p>
<p><strong>Date:</strong> <%= @event.start_date.strftime("%d %b %Y") %></p>
<p><%= @event.description %></p>

<% gcal_url = "https://calendar.google.com/calendar/render?" + {
  action: "TEMPLATE",
  text: @event.title,
  dates: "#{@event.start_date.strftime('%Y%m%dT%H%M%SZ')}/#{(@event.start_date + 1.hour).strftime('%Y%m%dT%H%M%SZ')}",
  details: @event.description
}.to_query %>
<%= link_to "Add to Google Calendar", gcal_url, target: "_blank", rel: "noopener noreferrer" %>

<% if @reminder %>
  <%= button_to "Remove Reminder", reminder_path(@reminder), method: :delete, class: "btn btn-danger" %>
<% else %>
  <%= button_to "Set Reminder", reminders_path(event_id: @event.id), method: :post, class: "btn btn-primary" %>
<% end %>

<%= link_to "Back to events", events_path %>
