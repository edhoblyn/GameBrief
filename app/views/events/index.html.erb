<div class="events-index">
  <div class="events-index__header container">
    <h1>Upcoming Events</h1>
  </div>

  <div class="container">
    <div class="events-grid" data-controller="glow-card">
      <% @events.each do |event| %>
        <%= link_to event_path(event),
              class: "event-glow-card",
              data: { "glow-card-target": "card" } do %>
          <div class="event-glow-card__inner">
            <div class="event-glow-card__date">
              <i class="fa fa-calendar"></i>
              <%= event.start_date.strftime("%-d %b %Y") %>
            </div>
            <div class="event-glow-card__title"><%= event.title %></div>
            <div class="event-glow-card__game">
              <i class="fa fa-gamepad"></i>
              <%= event.game.name %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
